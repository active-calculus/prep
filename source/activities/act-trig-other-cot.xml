<worksheet label="ws-act-trig-other-cot">
  <activity xml:id="act-trig-other-cot">
    <introduction>
      <p>
			In this activity, we develop the standard properties of the cotangent function, <m>r(t) = \cot(t)</m>.
		</p>
      <p/>
    </introduction>
