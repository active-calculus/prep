<worksheet label="ws-act-trig-inverse-arccos">
  <activity xml:id="act-trig-inverse-arccos">
    <introduction>
      <p>
			Use the special points on the unit circle (see, for instance, the start of <xref ref="sec-circular-sine-cosine">Section</xref>) to determine the exact values of each of the following numerical expressions.  Do so without using a computational device.
		</p>
      <p/>
    </introduction>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-0">
      <statement>
        <p>
          <m>\arccos(\frac{1}{2})</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos\!\left(\frac{1}{2}\right) = \frac{\pi}{3}</m></p>
      </solution>
    </task>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-1">
      <statement>
        <p>
          <m>\arccos(\frac{\sqrt{2}}{2})</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos\!\left(\frac{\sqrt{2}}{2}\right) = \frac{\pi}{4}</m></p>
      </solution>
    </task>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-2">
      <statement>
        <p>
          <m>\arccos(\frac{\sqrt{3}}{2})</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos\!\left(\frac{\sqrt{3}}{2}\right) = \frac{\pi}{6}</m></p>
      </solution>
    </task>
    <task workspace="3.5cm" xml:id="act-trig-inverse-arccos-task-3">
      <statement>
        <p>
          <m>\arccos(-\frac{1}{2})</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos\!\left(-\frac{1}{2}\right) = \frac{2\pi}{3}</m></p>
      </solution>
    </task>
    <task workspace="3.5cm" xml:id="act-trig-inverse-arccos-task-4">
      <statement>
        <p>
          <m>\arccos(-\frac{\sqrt{2}}{2})</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos\!\left(-\frac{\sqrt{2}}{2}\right) = \frac{3\pi}{4}</m></p>
      </solution>
    </task>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-5">
      <statement>
        <p>
          <m>\arccos(-\frac{\sqrt{3}}{2})</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos\!\left(-\frac{\sqrt{3}}{2}\right) = \frac{5\pi}{6}</m></p>
      </solution>
    </task>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-6">
      <statement>
        <p>
          <m>\arccos(-1)</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos(-1) = \pi</m></p>
      </solution>
    </task>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-7">
      <statement>
        <p>
          <m>\arccos(0)</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos(0) = \frac{\pi}{2}</m></p>
      </solution>
    </task>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-8">
      <statement>
        <p>
          <m>\cos(\arccos(-\frac{1}{2}))</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\cos\!\left(\arccos\!\left(-\frac{1}{2}\right)\right) = -\frac{1}{2}</m>, since cosine and arccosine are inverse functions.</p>
      </solution>
    </task>
    <task workspace="3cm" xml:id="act-trig-inverse-arccos-task-9">
      <statement>
        <p>
          <m>\arccos(\cos(\frac{7\pi}{6}))</m>
        </p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p><m>\arccos\!\left(\cos\!\left(\frac{7\pi}{6}\right)\right) = \frac{5\pi}{6}</m>, since <m>\cos\!\left(\frac{7\pi}{6}\right) = -\frac{\sqrt{3}}{2}</m> and <m>\arccos\!\left(-\frac{\sqrt{3}}{2}\right) = \frac{5\pi}{6}</m>.</p>
      </solution>
    </task>
    <answer>
      <p/>
    </answer>
    <solution>
      <p/>
    </solution>
  </activity>
</worksheet>
