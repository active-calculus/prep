    <task workspace="3cm" xml:id="act-trig-other-csc-task-5">
      <statement>
        <p>
						What is the period of the cosecant function?
					</p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p>
          The period of the cosecant function is <m>2\pi</m> radians.
        </p>
      </solution>
