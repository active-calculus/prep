      <p/>
    </introduction>
    <task workspace="3.5cm" xml:id="PA-circular-sine-task-0">
      <statement>
        <p>
						What is the exact value of <m>f( \frac{\pi}{4} )</m>? of <m>f( \frac{\pi}{3} )</m>?
					</p>
      </statement>
      <hint/>
      <answer/>
      <solution>
        <p>
          The exact value of <m>f\left(\frac{\pi}{4}\right) = \frac{\sqrt{2}}{2}</m>, and the exact value of <m>f\left(\frac{\pi}{3}\right) = \frac{\sqrt{3}}{2}</m>.
        </p>
      </solution>
    </task>
